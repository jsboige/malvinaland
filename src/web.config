<?xml version="1.0" encoding="utf-8"?>
<configuration>

    <!-- Espace organisateurs (solutions + guides) : protégé par Basic Auth IIS.
         Un seul user local Windows "orga-malvina" (mdp en dur). L'anonyme est coupé
         sur ce sous-arbre uniquement ; le reste du site reste public (joueurs).
         NB : les sections anonymous/basicAuthentication doivent être "unlocked" au
         niveau serveur (appcmd unlock config) pour que cette surcharge s'applique. -->
    <location path="organisateurs">
        <system.webServer>
            <security>
                <authentication>
                    <anonymousAuthentication enabled="false" />
                    <basicAuthentication enabled="true" />
                </authentication>
            </security>
        </system.webServer>
    </location>

    <system.webServer>
        <proxy>
            <preserveHostHeader>true</preserveHostHeader>
        </proxy>
        <defaultDocument>
            <files>
                <clear />
                <add value="index.html" />
            </files>
        </defaultDocument>
        <httpCompression>
            <dynamicTypes>
                <add mimeType="application/json" enabled="true" />
                <add mimeType="application/javascript" enabled="true" />
                <add mimeType="text/css" enabled="true" />
                <add mimeType="text/html" enabled="true" />
            </dynamicTypes>
            <staticTypes>`n                <add mimeType="image/svg+xml" enabled="true" /><add mimeType="application/json" enabled="true" /><add mimeType="application/javascript" enabled="true" /><add mimeType="text/css" enabled="true" /><add mimeType="text/html" enabled="true" /></staticTypes>
        </httpCompression>
        <rewrite>
            <rules>
                <rule name="HTTP to HTTPS redirect" stopProcessing="true">
                    <match url="(.*)" />
                    <conditions>
                        <add input="{HTTPS}" pattern="off" ignoreCase="true" />
                    </conditions>
                    <action type="Redirect" url="https://{HTTP_HOST}/{R:1}" redirectType="Permanent" />
                </rule>
                <!-- Espace organisateurs : désormais servi aux URL propres /organisateurs/*
                     (permalinks Eleventy). La réécriture vers content/organisateurs/ a été
                     retirée : elle servait un build ancien ET contournerait la protection
                     Basic Auth (URL Rewrite s'exécute avant l'authentification). La protection
                     est appliquée via <location path="organisateurs"> plus bas dans ce fichier. -->
                <!-- Les pages joueurs (mondes, carte, narration, personnages, login)
                     sont désormais générées directement aux URL propres par Eleventy
                     (permalinks) : plus de réécriture vers content/. Cela évite aussi
                     de servir l'ancien content/ non filtré (fuite des solutions). -->
                <!-- Anciennes URL /content/* -> redirection permanente vers l'URL propre. -->
                <rule name="Redirect legacy content to clean URL" stopProcessing="true">
                    <match url="^content/(.*)" />
                    <action type="Redirect" url="/{R:1}" redirectType="Permanent" />
                </rule>
            </rules>
        </rewrite>
        <httpProtocol>
            <customHeaders>
                <add name="X-Content-Type-Options" value="nosniff" />
                <add name="X-Frame-Options" value="DENY" />
                <add name="X-XSS-Protection" value="1; mode=block" />
                <add name="Content-Security-Policy" value="default-src 'self'; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline'; img-src 'self' data:; font-src 'self'; connect-src 'self';" />
                <add name="Strict-Transport-Security" value="max-age=31536000; includeSubDomains" />
            </customHeaders>
        </httpProtocol>
        <staticContent>
            <clientCache cacheControlMode="UseMaxAge" cacheControlMaxAge="7.00:00:00" />
            <!-- Types MIME nécessaires pour le bon fonctionnement du site -->
            <remove fileExtension=".json" />
            <remove fileExtension=".webp" />
            <remove fileExtension=".woff" />
            <remove fileExtension=".woff2" />
            <mimeMap fileExtension=".json" mimeType="application/json" />
            <mimeMap fileExtension=".webp" mimeType="image/webp" />
            <mimeMap fileExtension=".woff" mimeType="application/font-woff" />
            <mimeMap fileExtension=".woff2" mimeType="application/font-woff2" />
        </staticContent>
    </system.webServer>
</configuration>